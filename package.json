{
  "name": "tg-workout-mono",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev:user": "nest start user-service --watch",
    "dev:gateway": "nest start gateway --watch",
    "dev:workout": "nest start workout-service --watch",
    "dev:sync": "nest start sync-service --watch",
    "dev:parsing": "nest start parsing-service --watch",
    "dev:ai": "nest start ai-service --watch",
    "dev:bot": "nest start bot-service --watch",
    "dev:services": "concurrently \"npm:dev:user\" \"npm:dev:workout\" \"npm:dev:sync\" \"npm:dev:parsing\" \"npm:dev:ai\" \"npm:dev:bot\"",
    "build:user": "nest build user-service",
    "build:gateway": "nest build gateway",
    "build:workout": "nest build workout-service",
    "migration:user:generate": "typeorm-ts-node-commonjs migration:generate -d apps/user-service/src/data-source.ts",
    "migration:user:run": "typeorm-ts-node-commonjs migration:run -d apps/user-service/src/data-source.ts",
    "migration:user:revert": "typeorm-ts-node-commonjs migration:revert -d apps/user-service/src/data-source.ts",
    "migration:workout:generate": "typeorm-ts-node-commonjs migration:generate -d apps/workout-service/src/data-source.ts",
    "migration:workout:run": "typeorm-ts-node-commonjs migration:run -d apps/workout-service/src/data-source.ts",
    "migration:workout:revert": "typeorm-ts-node-commonjs migration:revert -d apps/workout-service/src/data-source.ts",
    "seed:workout": "ts-node -r tsconfig-paths/register apps/workout-service/src/seeds/exercise.seed.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/tg-workout-mono/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/tg-workout-mono/test/jest-e2e.json"
  },
  "dependencies": {
    "@apollo/gateway": "^2.13.0",
    "@apollo/subgraph": "^2.13.0",
    "@as-integrations/express5": "^1.1.2",
    "@keyv/redis": "^5.1.6",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^11.1.14",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@tma.js/init-data-node": "^2.0.6",
    "@types/amqplib": "^0.10.8",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.9",
    "axios": "^1.13.5",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^16.0.0",
    "grammy": "^1.41.1",
    "graphql": "^16.12.0",
    "graphql-type-json": "^0.3.2",
    "nestjs-pino": "^4.5.0",
    "openai": "^6.25.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "typesense-ts": "^0.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/contracts(|/.*)$": "<rootDir>/libs/contracts/src/$1",
      "^@app/core(|/.*)$": "<rootDir>/libs/core/src/$1",
      "^@app/database(|/.*)$": "<rootDir>/libs/database/src/$1",
      "^@app/utils(|/.*)$": "<rootDir>/libs/utils/src/$1"
    }
  }
}
