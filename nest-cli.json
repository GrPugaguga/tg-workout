{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/tg-workout-mono/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/tg-workout-mono/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/tg-workout-mono",
  "projects": {
    "ai-service": {
      "type": "application",
      "root": "apps/ai-service",
      "entryFile": "main",
      "sourceRoot": "apps/ai-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/ai-service/tsconfig.app.json"
      }
    },
    "ai_models": {
      "type": "library",
      "root": "libs/ai_models",
      "entryFile": "index",
      "sourceRoot": "libs/ai_models/src",
      "compilerOptions": {
        "tsConfigPath": "libs/ai_models/tsconfig.lib.json"
      }
    },
    "bot-service": {
      "type": "application",
      "root": "apps/bot-service",
      "entryFile": "main",
      "sourceRoot": "apps/bot-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/bot-service/tsconfig.app.json"
      }
    },
    "contracts": {
      "type": "library",
      "root": "libs/contracts",
      "entryFile": "index",
      "sourceRoot": "libs/contracts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contracts/tsconfig.lib.json"
      }
    },
    "core": {
      "type": "library",
      "root": "libs/core",
      "entryFile": "index",
      "sourceRoot": "libs/core/src",
      "compilerOptions": {
        "tsConfigPath": "libs/core/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway/tsconfig.app.json"
      }
    },
    "parsing-service": {
      "type": "application",
      "root": "apps/parsing-service",
      "entryFile": "main",
      "sourceRoot": "apps/parsing-service/src",
      "compilerOptions": {
        "webpackConfigPath": "webpack-typesense.config.js",
        "tsConfigPath": "apps/parsing-service/tsconfig.app.json"
      }
    },
    "sync-service": {
      "type": "application",
      "root": "apps/sync-service",
      "entryFile": "main",
      "sourceRoot": "apps/sync-service/src",
      "compilerOptions": {
        "webpackConfigPath": "webpack-typesense.config.js",
        "tsConfigPath": "apps/sync-service/tsconfig.app.json"
      }
    },
    "tg-workout-mono": {
      "type": "application",
      "root": "apps/tg-workout-mono",
      "entryFile": "main",
      "sourceRoot": "apps/tg-workout-mono/src",
      "compilerOptions": {
        "tsConfigPath": "apps/tg-workout-mono/tsconfig.app.json"
      }
    },
    "typesense": {
      "type": "library",
      "root": "libs/typesense",
      "entryFile": "index",
      "sourceRoot": "libs/typesense/src",
      "compilerOptions": {
        "tsConfigPath": "libs/typesense/tsconfig.lib.json"
      }
    },
    "user-service": {
      "type": "application",
      "root": "apps/user-service",
      "entryFile": "main",
      "sourceRoot": "apps/user-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/user-service/tsconfig.app.json"
      }
    },
    "utils": {
      "type": "library",
      "root": "libs/utils",
      "entryFile": "index",
      "sourceRoot": "libs/utils/src",
      "compilerOptions": {
        "tsConfigPath": "libs/utils/tsconfig.lib.json"
      }
    },
    "workout-service": {
      "type": "application",
      "root": "apps/workout-service",
      "entryFile": "main",
      "sourceRoot": "apps/workout-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/workout-service/tsconfig.app.json"
      }
    }
  }
}